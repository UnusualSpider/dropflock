# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
*.env

# Kubernetes / Talos — never commit credentials or cluster state
kubeconfig
kubeconfig.*
*.kubeconfig
talosconfig
*.talosconfig
.kube/
.talos/

# Plaintext secret manifests — use Sealed Secrets (k8s/postgres/secret.yaml)
# so the real values never reach git. The bootstrap flow generates a
# `*-plaintext.yaml` file via `kubectl create secret --dry-run`; this rule
# keeps it out of git even if a developer forgets the final `rm`.
*-plaintext.yaml
*-plaintext.yml
*_plaintext.yaml
*_plaintext.yml

# Argocd CLI session caches
.argocd/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
